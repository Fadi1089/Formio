{
  "name": "formio",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter ./apps/api dev",
    "dev:web": "pnpm --filter ./apps/web dev",
    "build": "pnpm build:web",
    "build:api": "pnpm --filter ./apps/api run build",
    "build:web": "pnpm --filter ./apps/web run build",
    "start": "pnpm --filter ./apps/web start"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "sharp"]
  }
}
