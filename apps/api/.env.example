# PostgreSQL connection string (pooled) — from Supabase project settings
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection URL (non-pooled) — required for Prisma migrations
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Port the API listens on locally
PORT=3001

# Supabase project URL — used to construct public media URLs
SUPABASE_URL=https://[project-ref].supabase.co

# JWT verification uses the SUPABASE_URL JWKS endpoint — no secret needed.

# HMAC secret for short-lived public form submit tokens (min 32 random characters).
PUBLIC_SUBMIT_TOKEN_SECRET=

# Optional: minimum ms before a submit token becomes valid (default 5000).
# PUBLIC_SUBMIT_MIN_DELAY_MS=5000

# Set to 1 (or a hop count) when the API sits behind a reverse proxy so rate limits use the real client IP.
# TRUST_PROXY=1
