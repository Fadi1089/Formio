# Public URL of this Next app (no trailing slash). Optional; if unset, the form
# builder shows a relative share path only — avoids hydration mismatches.
# Set in production (e.g. https://your-app.onrender.com).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base URL of the API service
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase project URL (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co

# Supabase publishable key (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...
